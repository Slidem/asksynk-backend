{
  "name": "asksynk-backend",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": "24.13.0",
    "pnpm": "10.15.0"
  },
  "scripts": {
    "dev": "pnpm --filter @asksynk/api dev",
    "migrate": "pnpm --filter @asksynk/migrations db:migrate",
    "generate-migrations": "pnpm --filter @asksynk/migrations db:generate",
    "new-custom-migration": "pnpm --filter @asksynk/migrations db:generate-custom",
    "localdev:up": "bash localdev/up.sh",
    "localdev:down": "bash localdev/down.sh",
    "localdev:reset": "bash localdev/reset.sh",
    "test:integration:up": "docker compose -f localdev/docker-compose.test.yml up -d --wait && GARAGE_CONTAINER=asksynk-garage-test bash localdev/garage/init.sh",
    "test:integration:down": "docker compose -f localdev/docker-compose.test.yml down -v",
    "test:integration": "pnpm --filter @asksynk/api test",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier -w .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "secret:better-auth": "pnpm --filter @asksynk/scripts generate-secret",
    "prepare-storage": "pnpm --filter @asksynk/scripts prepare-storage"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "eslint": "^9.7.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  }
}
