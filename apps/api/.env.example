ENVIRONMENT=dev
DATABASE_URL=postgres://asksynk:asksynk@localhost:5432/asksynk
AUTH_SECRET=your-secret-key-at-least-32-characters-long
APP_BASE_URL=http://localhost:5173
TRUSTED_ORIGINS=http://localhost:5173
HASHID_SALT=your-hashid-salt

# Email transport. EMAIL_PROVIDER selects the impl: mailpit (default, local) | agentmail.
EMAIL_PROVIDER=mailpit
# mailpit provider (local SMTP via localdev docker compose)
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025
# agentmail provider
AGENTMAIL_API_KEY=your-agentmail-api-key
AGENTMAIL_INBOX_ID=your-agentmail-inbox-id


# Swagger UI is served at /docs (JSON at /docs-json). When ENVIRONMENT=production
# the docs routes are gated behind Basic-auth using these credentials.
SWAGGER_USER=docs
SWAGGER_PASSWORD=change-me

# Object storage (Garage / S3-compatible)
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
# Garage key format: "GK" + 24 hex (access), 64 hex (secret). Must match localdev/garage/init.sh.
S3_ACCESS_KEY_ID=GKabcdef0123456789abcdef01
S3_SECRET_ACCESS_KEY=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789
S3_BUCKET_PRIVATE=asksynk-private
S3_BUCKET_PUBLIC=asksynk-public
# Stable base url for public objects (Garage web endpoint / CDN in front).
# Garage web (:3902) resolves the bucket from the subdomain (root_domain .web.garage.localhost),
# so the bucket name must be in the host. Browsers auto-resolve *.localhost to 127.0.0.1.
# On Railway: needs a 2nd public endpoint besides the S3 API (S3 API stays public for
# presigned urls). Add `[s3_web] bind_addr=":3904"` to the Garage template, point a custom
# domain at target port 3904, and set this to that domain. prepare-storage registers the
# domain host as a Garage bucket global alias (Railway has no wildcard subdomains).
S3_PUBLIC_BASE_URL=http://asksynk-public.web.garage.localhost:3902
S3_FORCE_PATH_STYLE=true

# Garage bootstrap (`pnpm run prepare-storage`, run as the Railway predeploy).
# Admin API of the Garage service; token must match its garage.toml `[admin] admin_token`.
# On Railway point these at the Garage service's private domain (e.g. http://garage.railway.internal:3903).
GARAGE_ADMIN_ENDPOINT=http://localhost:3903
GARAGE_ADMIN_TOKEN=localdev-admin-token
CORS_EXTRA_ORIGINS=http://localhost:3000

# Google Calendar integration (Google Cloud Console → OAuth 2.0 Web client).
# Enable the Google Calendar API, configure the OAuth consent screen (External,
# add your email as a test user), then set the redirect URI below as an
# Authorized redirect URI on the OAuth client.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/calendar-integrations/google/callback
# Frontend URL the OAuth callback redirects to after connecting (a `connected=<provider>`
# query param is appended). Mandatory.
CALENDAR_OAUTH_REDIRECT_URL=http://localhost:5173/settings/integrations
