{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  "eslint.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "jest.jestCommandLine": "node_modules/jest/bin/jest.js --config jest.config.ts",
  "jest.rootPath": "apps/api",
  "jest.shell": { "path": "/bin/zsh", "args": ["-i"] },
  "jest.runMode": "on-demand",
  "cSpell.words": [
    "agentmail",
    "Asksynk",
    "docorators",
    "hashid",
    "hashids",
    "Millis",
    "Readables",
    "responfications",
    "rrule",
    "suggestee",
    "Syncable",
    "tmpl",
    "Upserted"
  ],
  "C_Cpp.errorSquiggles": "disabled"
}
